# Python
.pytest_cache/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv

# CSV data files - protect membership data
*.csv
data/*.csv
!archive/*.csv

# Local databases / generated data artifacts (never commit PII)
data/*.db
data/*.sqlite
api/*.db
api/*.sqlite
data/*.xml
data/*.ods
data/*.png
data/*.jpg
data/*.jpeg
data/*.pdf
data/*.docx
data/*.html
data/duplicate_report.*
data/readings/
data/books-wordpress.html

# Allow JSON data files (generated from CSV, safe to commit)
!astro-app/public/data/*.json

# Environment files (secrets — .env.schema is committed as the schema)
.env
.env.local
.env.*.local
.env.development
.env.test
.env.staging
.env.production
.env.prod

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# User-uploaded profile images (local demo)
uploads/

# Netlify
.netlify/

# Node.js / Astro
node_modules/
astro-app/node_modules/
astro-app/dist/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
