    "astro": "astro",
    "export-data": "python3 ../scripts/export_member_data.py \"../data/NaBA Members.csv\" || true"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21"
  }
}
