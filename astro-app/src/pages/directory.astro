---
import Layout from '../layouts/Layout.astro';
import entriesData from '../../public/data/directoryEntries.json';

type EntryType = 'individual' | 'organization' | 'business';

interface DirectoryEntry {
  id: number;
  name: string;
  type: EntryType;
  role: string;
  org?: string;
  location: string;
  website?: string;
  tags: string[];
}

const entries = entriesData as DirectoryEntry[];

// Pre-split entries by type; actual view selection happens on the client
const memberEntries = entries.filter(
  (e) => e.type === 'individual' || e.type === 'organization'
);
const businessEntries = entries.filter((e) => e.type === 'business');

const pageTitle = 'Directory';
---

<Layout title={pageTitle}>
  <main style="max-width: 960px; margin: 0 auto; padding: 2rem 1.5rem;">
    <header style="margin-bottom: 1.5rem;">
      <h1 style="margin: 0 0 0.5rem 0;">{pageTitle}</h1>
      <p style="margin: 0; color: #555;">
        This is a prototype directory using sample data. In the future this will be populated from live membership data.
      </p>
    </header>

    <nav
      style="display: flex; gap: 0.75rem; margin-bottom: 1.5rem; flex-wrap: wrap;"
      id="directory-view-toggle"
    >
      <a
        href="/directory?view=members"
        data-view="members"
        style="padding: 0.5rem 1rem; border-radius: 999px; border: 1px solid #333; background: #333; color: #fff; text-decoration: none; font-size: 0.9rem;"
      >
        Membership Directory
      </a>
      <a
        href="/directory?view=businesses"
        data-view="businesses"
        style="padding: 0.5rem 1rem; border-radius: 999px; border: 1px solid #ccc; background: #fff; color: #333; text-decoration: none; font-size: 0.9rem;"
      >
        Business Directory
      </a>
    </nav>

    <section
      id="directory-members"
      data-section="members"
      style="display: grid; gap: 1.25rem; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));"
    >
      {memberEntries.map((entry) => (
        <article
          style="border-radius: 0.75rem; padding: 1.25rem 1.5rem; border: 1px solid #e0e0e0; box-shadow: 0 2px 6px rgba(0,0,0,0.03);"
        >
          <h2 style="margin: 0 0 0.25rem 0; font-size: 1.1rem;">{entry.name}</h2>
          <p style="margin: 0 0 0.25rem 0; color: #555; font-size: 0.95rem;">
            {entry.role}
          </p>
          <p style="margin: 0 0 0.5rem 0; color: #777; font-size: 0.9rem;">
            {entry.location}
          </p>
          {entry.website && (
            <p style="margin: 0 0 0.5rem 0; font-size: 0.9rem;">
              <a href={entry.website} target="_blank" rel="noreferrer" style="color: #0057b8;">
                Visit website
              </a>
            </p>
          )}
          <div style="display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.5rem;">
            {entry.tags.map((tag) => (
              <span
                style="font-size: 0.8rem; padding: 0.15rem 0.5rem; border-radius: 999px; background: #f3f3f3; color: #555;"
              >
                {tag}
              </span>
            ))}
          </div>
        </article>
      ))}
    </section>

    <section
      id="directory-businesses"
      data-section="businesses"
      style="display: none; gap: 1.25rem; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));"
    >
      {businessEntries.map((entry) => (
        <article
          style="border-radius: 0.75rem; padding: 1.25rem 1.5rem; border: 1px solid #e0e0e0; box-shadow: 0 2px 6px rgba(0,0,0,0.03);"
        >
          <h2 style="margin: 0 0 0.25rem 0; font-size: 1.1rem;">{entry.name}</h2>
          <p style="margin: 0 0 0.25rem 0; color: #555; font-size: 0.95rem;">
            {entry.role}
          </p>
          <p style="margin: 0 0 0.5rem 0; color: #777; font-size: 0.9rem;">
            {entry.location}
          </p>
          {entry.website && (
            <p style="margin: 0 0 0.5rem 0; font-size: 0.9rem;">
              <a href={entry.website} target="_blank" rel="noreferrer" style="color: #0057b8;">
                Visit website
              </a>
            </p>
          )}
          <div style="display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.5rem;">
            {entry.tags.map((tag) => (
              <span
                style="font-size: 0.8rem; padding: 0.15rem 0.5rem; border-radius: 999px; background: #f3f3f3; color: #555;"
              >
                {tag}
              </span>
            ))}
          </div>
        </article>
      ))}
    </section>
  </main>

  <script>
    // Client-side toggle so query param and pills stay in sync
    (function () {
      var params = new URLSearchParams(window.location.search);
      var view = params.get('view') === 'businesses' ? 'businesses' : 'members';

      var membersSection = document.querySelector('#directory-members');
      var businessesSection = document.querySelector('#directory-businesses');
      var pills = document.querySelectorAll('#directory-view-toggle a[data-view]');

      function applyView(nextView) {
        view = nextView;

        if (membersSection && businessesSection) {
          if (view === 'members') {
            membersSection.style.display = 'grid';
            businessesSection.style.display = 'none';
          } else {
            membersSection.style.display = 'none';
            businessesSection.style.display = 'grid';
          }
        }

        pills.forEach(function (pill) {
          var pillView = pill.getAttribute('data-view');
          var isActive = pillView === view;
          pill.style.borderColor = isActive ? '#333' : '#ccc';
          pill.style.background = isActive ? '#333' : '#fff';
          pill.style.color = isActive ? '#fff' : '#333';
        });

        var url = new URL(window.location.href);
        url.searchParams.set('view', view);
        window.history.replaceState({}, '', url.toString());
      }

      pills.forEach(function (pill) {
        pill.addEventListener('click', function (event) {
          event.preventDefault();
          var pillView = pill.getAttribute('data-view');
          if (pillView === 'members' || pillView === 'businesses') {
            applyView(pillView);
          }
        });
      });

      applyView(view);
    })();
  </script>
</Layout>

