---
import Layout from '../layouts/Layout.astro';
import MapComponent from '../components/Map';
import stateMappingData from '../../public/data/stateMapping.json';

const stateMapping = stateMappingData as Record<string, string>;
const apiBaseUrl =
  typeof import.meta.env.PUBLIC_MEMBERSHIP_API_URL === 'string' && import.meta.env.PUBLIC_MEMBERSHIP_API_URL
    ? import.meta.env.PUBLIC_MEMBERSHIP_API_URL
    : import.meta.env.DEV
      ? 'http://localhost:8000'
      : '';
---

<Layout title="Member Map - NaBA Directory">
  <MapComponent
    client:load
    apiBaseUrl={apiBaseUrl}
    stateMapping={stateMapping}
  />
</Layout>

