# Copy to `.env` for local development (Astro loads `PUBLIC_*` from here).
# `import.meta.env.PUBLIC_MEMBERSHIP_API_URL` — base URL of the FastAPI service (no trailing slash).
PUBLIC_MEMBERSHIP_API_URL=http://localhost:8000
# Optional: WordPress “become a member” / register URL
PUBLIC_JOIN_MEMBERSHIP_URL=https://natural-building-alliance.org/register/
